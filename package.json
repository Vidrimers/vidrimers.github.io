{
  "name": "react-portfolio",
  "version": "2.0.0",
  "description": "React Portfolio Website - Modern portfolio built with React and Vite",
  "author": "Yaroslav Shiryakov",
  "homepage": "https://vidrimers.github.io",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "dev:frontend": "vite",
    "devtun": "tuna http 3000 --domain=vidrimers.ru.tuna.am",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "test": "vitest --run",
    "test:watch": "vitest",
    "server": "node server/server.js",
    "server:dev": "nodemon server/server.js",
    "start": "concurrently \"npm run server\" \"npm run dev:frontend\"",
    "start:dev": "concurrently \"npm run server:dev\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "sass": "1.89.2",
    "supertest": "^7.2.2",
    "terser": "^5.46.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite3": "^6.0.1"
  }
}
